{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/settlement-readiness-report.schema.json",
  "title": "Settlement Readiness Report",
  "description": "A final readiness report for summarizing AI agent settlement review status, human gate results, marketplace rule checks, dispute status, and settlement routing recommendations.",
  "type": "object",
  "additionalProperties": false,
  "required": ["settlement_readiness_report"],
  "properties": {
    "settlement_readiness_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "report_id",
        "report_scope",
        "source_reviews",
        "readiness_summary",
        "blocking_status",
        "settlement_route",
        "risk_summary",
        "recommendation",
        "audit"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "report_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "report_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "report_type",
            "purpose",
            "settlement_decision_requested"
          ],
          "properties": {
            "report_type": {
              "type": "string",
              "enum": [
                "settlement_readiness_summary",
                "royalty_candidate_readiness",
                "commerce_settlement_readiness",
                "marketplace_settlement_readiness",
                "dispute_resolution_readiness",
                "other"
              ]
            },
            "purpose": {
              "type": "string"
            },
            "settlement_decision_requested": {
              "type": "boolean"
            }
          }
        },
        "source_reviews": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "settlement_review_ref",
            "human_settlement_gate_ref",
            "marketplace_rule_review_ref",
            "dispute_appeal_record_refs"
          ],
          "properties": {
            "settlement_review_ref": {
              "type": ["string", "null"]
            },
            "human_settlement_gate_ref": {
              "type": ["string", "null"]
            },
            "marketplace_rule_review_ref": {
              "type": ["string", "null"]
            },
            "dispute_appeal_record_refs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "agentic_royalty_path_ref": {
              "type": ["string", "null"]
            },
            "path_royalty_weighting_ref": {
              "type": ["string", "null"]
            }
          }
        },
        "readiness_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "evidence_ready",
            "human_gate_ready",
            "marketplace_rule_ready",
            "dispute_clear",
            "settlement_ready"
          ],
          "properties": {
            "evidence_ready": {
              "type": "boolean"
            },
            "human_gate_ready": {
              "type": "boolean"
            },
            "marketplace_rule_ready": {
              "type": "boolean"
            },
            "dispute_clear": {
              "type": "boolean"
            },
            "settlement_ready": {
              "type": "boolean"
            },
            "summary_notes": {
              "type": "string"
            }
          }
        },
        "blocking_status": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "blocked",
            "blockers"
          ],
          "properties": {
            "blocked": {
              "type": "boolean"
            },
            "blockers": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "blocker_type",
                  "blocker_ref",
                  "severity",
                  "resolution_required"
                ],
                "properties": {
                  "blocker_type": {
                    "type": "string",
                    "enum": [
                      "missing_evidence",
                      "human_review_pending",
                      "marketplace_rule_condition",
                      "open_dispute",
                      "legal_review_required",
                      "payment_threshold_not_met",
                      "beneficiary_identity_unconfirmed",
                      "risk_policy_block",
                      "other"
                    ]
                  },
                  "blocker_ref": {
                    "type": ["string", "null"]
                  },
                  "severity": {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high",
                      "critical"
                    ]
                  },
                  "resolution_required": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "settlement_route": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "recommended_route",
            "route_reason",
            "next_required_action"
          ],
          "properties": {
            "recommended_route": {
              "type": "string",
              "enum": [
                "ready_for_settlement_engine",
                "conditional_settlement_hold",
                "return_to_human_gate",
                "return_to_marketplace_rule_review",
                "return_to_dispute_review",
                "requires_legal_review",
                "rejected",
                "not_ready"
              ]
            },
            "route_reason": {
              "type": "string"
            },
            "next_required_action": {
              "type": "string",
              "enum": [
                "execute_settlement_engine_review",
                "collect_more_evidence",
                "complete_human_review",
                "complete_marketplace_rule_review",
                "resolve_dispute",
                "complete_legal_review",
                "confirm_payment_threshold",
                "confirm_beneficiary_identity",
                "none",
                "other"
              ]
            },
            "settlement_engine_ref": {
              "type": ["string", "null"]
            }
          }
        },
        "risk_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "risk_level",
            "risk_acceptable",
            "risk_notes"
          ],
          "properties": {
            "risk_level": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high",
                "critical",
                "unknown"
              ]
            },
            "risk_acceptable": {
              "type": "boolean"
            },
            "risk_notes": {
              "type": "string"
            }
          }
        },
        "recommendation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "readiness_decision",
            "decision_reason",
            "payout_decision_created",
            "legal_claim_created"
          ],
          "properties": {
            "readiness_decision": {
              "type": "string",
              "enum": [
                "ready",
                "conditionally_ready",
                "blocked",
                "rejected",
                "escalated",
                "not_ready"
              ]
            },
            "decision_reason": {
              "type": "string"
            },
            "payout_decision_created": {
              "type": "boolean"
            },
            "legal_claim_created": {
              "type": "boolean"
            }
          }
        },
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "report_status",
            "finalized",
            "requires_follow_up",
            "notes"
          ],
          "properties": {
            "report_status": {
              "type": "string",
              "enum": [
                "draft",
                "pending_review",
                "finalized",
                "blocked",
                "rejected",
                "escalated"
              ]
            },
            "finalized": {
              "type": "boolean"
            },
            "requires_follow_up": {
              "type": "boolean"
            },
            "notes": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
